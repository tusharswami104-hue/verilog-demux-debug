module mux_by_basicgate( input a,s1,s2, output op1,op2,op3,op4 );
    assign op1 = (!s1)&(!s2)&a;
    assign op2 = (!s1)&(s2)&a;
    assign op3 = (s1)&(!s2)&a;
    assign op4 = (s1)&(s2)&a;
endmodule
